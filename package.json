{
  "name": "lab-management",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "desktop": "pnpm --filter @lab/desktop dev",
    "db:generate": "pnpm --filter @lab/db prisma:generate",
    "db:migrate": "pnpm --filter @lab/db prisma:migrate",
    "db:seed": "pnpm --filter @lab/db seed"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.5.4"
  },
  "engines": { "node": ">=20.10.0", "pnpm": ">=9.0.0" }
}
