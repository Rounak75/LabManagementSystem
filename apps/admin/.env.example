# Supabase project (production values set in Vercel; local values point to test project)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Shared Supabase JWT secret for verifying Edge Function-issued tokens.
# Find this in Supabase Studio → Project Settings → API → JWT Secret.
SUPABASE_JWT_SECRET=your-jwt-secret
