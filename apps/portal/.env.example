# Patient portal environment variables.
# Set these in Vercel project Settings → Environment Variables (production).
# For local dev, copy this file to apps/portal/.env.local and fill in real values.

# Supabase project URL — from Supabase Dashboard → Project Settings → API → Project URL.
# Exposed to the browser (NEXT_PUBLIC_ prefix). Safe to commit.
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co

# Anon key — from Supabase Dashboard → Project Settings → API → anon public key.
# Exposed to the browser. RLS protects all data; the key only grants the rights anon has.
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Service role key — from Supabase Dashboard → Project Settings → API → service_role secret.
# SERVER-ONLY. Bypasses RLS. Used by portal API routes for trusted lookups
# (e.g. finding a patient before they have a JWT). NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=<server-only — never exposed to browser>

# JWT signing secret — from Supabase Dashboard → Project Settings → API → JWT Settings → JWT Secret.
# Must match exactly so Supabase can verify tokens minted by the portal.
# A mismatch causes silent RLS failures (all queries return empty).
SUPABASE_JWT_SECRET=<same secret your Supabase project uses to sign auth JWTs>

# Public base URL the portal is served at — used when the portal needs to
# generate absolute URLs back to itself (e.g. links in outbound emails).
# After first deploy, set this to the Vercel-assigned subdomain, then update
# again if a custom domain is attached.
PORTAL_BASE_URL=https://golmurijanchghar.vercel.app

# Razorpay portal keys — OPTIONAL. Required only if/when Razorpay is flipped on
# (KYC currently blocked, so UPI direct is the active payment path). When Razorpay
# clears, set these and flip LabSettings.preferredPaymentGateway to "Razorpay".
# RAZORPAY_PORTAL_KEY_ID=<your-key-id>
# RAZORPAY_PORTAL_KEY_SECRET=<your-key-secret>
